# Application
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# Database (Supabase Supavisor pooler — port 6543)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.example.supabase.co:6543/postgres

# Supabase Auth
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Security
JWT_SECRET_KEY=dev-only-jwt-secret-change-in-production-0123456789abcdef

# Cache
REDIS_URL=redis://localhost:6379/0

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Frontend (Vercel) — points to Docker backend
NEXT_PUBLIC_API_URL=http://localhost:8010

# Backend CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Agentic code refactoring (ADR-004) — disabled by default; admin + consent required
REFACTORING_ENABLED=false
REFACTORING_SANDBOX_ROOT=
REFACTORING_VERIFY_COMMAND=
REFACTORING_FEEDBACK_PATH=.taskflow/refactoring-feedback.jsonl
